# URL de la base de datos
# Para desarrollo (SQLite, archivo local):
DATABASE_URL=sqlite:///./gameconnect.db
# Para producción (PostgreSQL, ejemplo):
# DATABASE_URL=postgresql://usuario:password@localhost:5432/gameconnect

# Clave secreta para firmar tokens JWT
# IMPORTANTE: generá una nueva con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambiame_por_una_clave_random_de_al_menos_32_caracteres

# Algoritmo y duración del token
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Entorno (development / production)
ENVIRONMENT=development

# Email para el reporte de bugs (API de Resend, manda por HTTPS).
# Probamos Gmail SMTP primero, pero Render bloquea los puertos de SMTP
# salientes — por eso usamos un servicio que manda por HTTPS.
# 1. Creá una cuenta gratis en resend.com (usá el mail de BUG_REPORT_TO_EMAIL
#    como mail de la cuenta: en el plan gratis sin dominio verificado solo
#    se puede mandar a esa misma dirección)
# 2. Generá una API key en la sección "API Keys"
# Si dejás RESEND_API_KEY vacío, no se manda el mail: el reporte se guarda
# igual en la BD y se loguea por consola (sirve para desarrollo local).
RESEND_API_KEY=
BUG_REPORT_FROM_EMAIL=onboarding@resend.dev
BUG_REPORT_TO_EMAIL=tinchografdev@gmail.com
