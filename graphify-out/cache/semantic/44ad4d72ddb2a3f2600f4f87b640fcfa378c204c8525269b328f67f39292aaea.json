{"nodes": [{"id": "readme_gameconnect", "label": "GameConnect project", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_anti_troll_system", "label": "Anti-troll system (5 barriers)", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Combines double confirmation, a 7-day review time window, mandatory 30+ character comments, trust-score-weighted reviews, and outlier detection (with 5+ prior reviews) to deter toxic/fraudulent reviews."}, {"id": "readme_gameprofile_design", "label": "GameProfile separate-per-user-per-game design", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A player can be Mid in LAS for League of Legends and AWPer in SA for Counter Strike; modeling GameProfile as an intermediate table between User and Game lets each profile have independent roles/server/rank without duplication, preserving referential integrity."}, {"id": "readme_sqlite_then_postgres", "label": "SQLite-first then PostgreSQL decision", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SQLite is a zero-config file, perfect for development; in production only DATABASE_URL changes and SQLAlchemy/Alembic handle the rest without touching application code."}, {"id": "readme_url_based_filters", "label": "URL-based search filters decision", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Filters like /searches?game_slug=...&server=... are shareable and reload-safe; keeping filters only in React state would break both reload persistence and link sharing."}, {"id": "readme_render_vercel_split", "label": "Render + Vercel split infrastructure decision", "file_type": "rationale", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Render hosts the Python backend plus managed PostgreSQL; Vercel hosts the static frontend with global CDN \u2014 standard separation where each platform is optimized for its role, both with generous free tiers and auto-deploy on push."}, {"id": "readme_fastapi_backend", "label": "FastAPI backend stack", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_react_frontend", "label": "React 19 + Vite frontend stack", "file_type": "concept", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "readme_roadmap", "label": "Project roadmap (backend/frontend/deploy phases)", "file_type": "document", "source_file": "README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "readme_gameconnect", "target": "fase_2_integracion_fase2", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_gameconnect", "target": "fase_3_integracion_fase3", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_gameconnect", "target": "fase_4_integracion_fase4", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "README.md", "source_location": null, "weight": 1.0}, {"source": "readme_gameconnect", "target": "fase_4_5_integracion_f