{"nodes": [{"id": "fase_5_integracion_fase5", "label": "Fase 5: Confirmaci\u00f3n de partidas y reviews anti-troll", "file_type": "rationale", "source_file": "FASE_5_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Closes the MVP: double-confirmation prevents unilateral phantom reviews, weight is calculated at review creation time (snapshot semantics) so later trust changes don't retroactively alter past reviews, 7-day time window prevents late revenge reviews, weighted average (not simple average) reflects reviewer trust, and outlier detection needs a baseline of prior reviews before flagging."}, {"id": "fase_5_integracion_reputation_py", "label": "app/core/reputation.py", "file_type": "code", "source_file": "FASE_5_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "fase_5_integracion_review_schema", "label": "app/schemas/review.py", "file_type": "code", "source_file": "FASE_5_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "fase_5_integracion_reviews_router", "label": "app/routers/reviews.py", "file_type": "code", "source_file": "FASE_5_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "fase_5_integracion_confirm_played_endpoint", "label": "/searches/{id}/confirm-played endpoint", "file_type": "code", "source_file": "FASE_5_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "fase_5_integracion_double_confirmation", "label": "Double confirmation anti-troll barrier", "file_type": "rationale", "source_file": "FASE_5_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No unilateral system prevents