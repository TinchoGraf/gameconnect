{"nodes": [{"id": "fase_3_integracion_fase3", "label": "Fase 3: Perfiles de juego por usuario", "file_type": "rationale", "source_file": "FASE_3_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Introduces GameProfile as an intermediate table with its own attributes (roles, rank, server) rather than a plain join table, enabling dynamic role/server validation read from DB instead of hardcoded regex, and cross-field validation (main_role must be in roles) via Pydantic @model_validator."}, {"id": "fase_3_integracion_game_profile_schema", "label": "app/schemas/game_profile.py", "file_type": "code", "source_file": "FASE_3_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "fase_3_integracion_game_profiles_router", "label": "app/routers/game_profiles.py", "file_type": "code", "source_file": "FASE_3_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "fase_3_integracion_dynamic_validation", "label": "Dynamic vs static validation", "file_type": "rationale", "source_file": "FASE_3_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Validation rules depend on DB seed data, not hardcoded regex, so adding a new role to a game in the seed automatically adjusts validation without code changes."}, {"id": "fase_3_integracion_defer_migrations", "label": "Decision to defer Alembic to a later phase", "file_type": "rationale", "source_file": "FASE_3_INTEGRACION.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No real data exists yet (all test data), so dropping and regenerating the DB is faster and more didactic than configuring migrations prematurely."}], "edges": [{"source": "fase_3_integracion_fase